{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "outDir": "dist/electron",
    "rootDir": "."
  },
  "include": ["electron/**/*.ts", "electron/**/*.cts", "src/types/index.ts", "src/shared/**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
