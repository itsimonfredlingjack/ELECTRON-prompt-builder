{
  "name": "i-prompt-bad",
  "version": "1.0.0",
  "type": "module",
  "description": "Local AI Prompt Builder - Transform rough ideas into optimized prompts",
  "main": "dist/electron/electron/main.js",
  "scripts": {
    "start": "concurrently \"DEV_SERVER_PORT=5179 vite --host 127.0.0.1 --port 5179 --strictPort\" \"tsc -p tsconfig.node.json --watch --preserveWatchOutput\" \"wait-on dist/electron/electron/main.js http://127.0.0.1:5179 && DEV_SERVER_PORT=5179 electron .\"",
    "dev": "vite",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "test": "vitest run",
    "electron:dev": "concurrently \"DEV_SERVER_PORT=5179 vite --host 127.0.0.1 --port 5179 --strictPort\" \"tsc -p tsconfig.node.json --watch --preserveWatchOutput\" \"wait-on dist/electron/electron/main.js http://127.0.0.1:5179 && DEV_SERVER_PORT=5179 electron .\"",
    "electron:build": "npm run build && electron-builder",
    "lint": "eslint . --ext .ts,.tsx,.cts"
  },
  "keywords": [
    "electron",
    "prompt",
    "ai",
    "ollama"
  ],
  "author": {
    "name": "AI Prompt Builder",
    "email": "ai-prompt-builder@localhost"
  },
  "homepage": "https://github.com/local/ai-prompt-builder",
  "license": "MIT",
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.7",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  },
  "pnpm": {
    "overrides": {
      "@xmldom/xmldom@<0.8.13": "0.8.13",
      "ajv@<6.14.0": "6.14.0",
      "axios@>=1.0.0 <1.15.0": "1.15.0",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "esbuild@<=0.24.2": "0.25.12",
      "flatted@<=3.4.1": "3.4.2",
      "follow-redirects@<=1.15.11": "1.16.0",
      "lodash@<=4.17.23": "4.18.0",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "vite@<=6.4.1": "6.4.2"
    }
  }
}
